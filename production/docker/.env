COMPOSE_PROJECT_NAME=dice-be

# Optional: override published ports (see docker-compose.yml)
# DICE_BE_PORT=5020
# DICE_FE_PORT=8080

# API base URL baked into the React build (browser must reach this host:port).
# Default matches docker-compose publishing dice-be on localhost:5020.
# REACT_APP_DICE_SERVER=http://localhost:5020

# Front-end Git source for dice-fe image build (optional overrides)
# DICE_FE_REPO=https://github.com/christroutner/dice-fe.git
# DICE_FE_GIT_REF=main

# Secrets for the API — set before production use (also read by dice-be service)
# MNEMONIC=
# ADMIN_PASSWORD=
