COMPOSE_PROJECT_NAME=pma-be

# Optional: override published ports (see docker-compose.yml)
# PMA_BE_PORT=5020
# PMA_FE_PORT=8080

# API base URL baked into the React build (browser must reach this host:port).
# Default matches docker-compose publishing pma-be on localhost:5020.
# REACT_APP_PMA_SERVER=http://localhost:5020

# Secrets for the API — set before production use (also read by pma-be service)
# MNEMONIC=
# ADMIN_PASSWORD=
